# Spotify Integration
# To get these, create a Spotify app at https://developer.spotify.com/dashboard
# Then use the authorization code flow to get a refresh token:
# 1. Visit: https://accounts.spotify.com/authorize?client_id=YOUR_CLIENT_ID&response_type=code&redirect_uri=http://localhost:3000/callback&scope=user-read-currently-playing%20user-read-playback-state
# 2. Copy the 'code' from the redirect URL
# 3. Exchange it: curl -d grant_type=authorization_code -d code=YOUR_CODE -d redirect_uri=http://localhost:3000/callback -H "Authorization: Basic BASE64(client_id:client_secret)" https://accounts.spotify.com/api/token
# 4. Copy the refresh_token from the response

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
